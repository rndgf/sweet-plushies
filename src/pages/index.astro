---
import Layout from "../layouts/Layout.astro";
import Plush from "../components/Plush.astro";
import Bee from "../components/Bee.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
import SectionHead from "../components/SectionHead.astro";
import PlushCard from "../components/PlushCard.astro";
import Step from "../components/Step.astro";
import { plushies } from "../data";

const stats = [
  { value: "4", label: "créatrices passionnées" },
  { value: "125+", label: "mètres de laine tricotés" },
  { value: "200+", label: "heures de crochetage" },
];

const orderSteps = [
  {
    title: "Choisis ton modèle",
    body: "Regarde la galerie, craque pour ta préférée, retiens son nom.",
  },
  {
    title: "Contacte l'une d'entre nous dans la cour",
    body: "Et passe ta commande. Un acompte en espèce te sera demandée.",
  },
  {
    title: "Récupère ta nouvelle amie",
    body: "Une fois confectionnée, ta peluche te sera remise en main propre.",
  },
  {
    title: "Ramène-la à la maison",
    body: "Et profite bien de ta nouvelle amie colorée et douce comme un câlin.",
  },
];
---

<Layout>
  <main id="top">
    {/* ---------- Hero ---------- */}
    <section
      class="relative overflow-hidden lg:overflow-visible max-w-[1100px] mx-auto px-5 sm:px-8 lg:px-16 py-6 lg:py-14 grid lg:grid-cols-[1.7fr_0.6fr] gap-4 lg:gap-8 items-center"
    >
      <div
        class="absolute rounded-full blur-[60px] opacity-55 pointer-events-none z-0 bg-pink w-[260px] h-[260px] -top-[40px] -left-[60px]"
      >
      </div>
      <div
        class="absolute rounded-full blur-[60px] opacity-55 pointer-events-none z-0 bg-mint w-[240px] h-[240px] -bottom-[60px] right-[10%]"
      >
      </div>
      <div
        class="absolute rounded-full blur-[60px] opacity-55 pointer-events-none z-0 bg-cream w-[200px] h-[200px] top-[40%] -right-[40px]"
      >
      </div>

      <div class="relative z-10 text-center lg:text-left">
        <Eyebrow>Au crochet · Fait main · Gros câlins</Eyebrow>
        <h1
          class="display-h1 text-[clamp(1.6rem,3.8vw,2.8rem)] mb-4 leading-tight"
        >
          De petites peluches toutes douces,
          <br class="hidden lg:inline" />
          <span class="hl">crochetées avec amour.</span>
        </h1>
        <p
          class="text-[1.02rem] text-plum-soft max-w-[48ch] mb-6 mx-auto lg:mx-0"
        >
          Nous sommes une équipe de <strong>quatre créatrices</strong>,
          collégiennes, et nous crochetons des peluches à la récré, après les
          cours. Et nous les proposons à la vente.
        </p>
        <div class="flex flex-wrap gap-3 justify-center lg:justify-start">
          <Button href="#gallery" variant="primary">Voir les peluches</Button>
          <Button href="/equipe" variant="ghost">Qui sommes-nous →</Button>
        </div>
      </div>

      <div
        class="relative z-10 max-w-[140px] sm:max-w-[160px] lg:max-w-[220px] mx-auto order-first lg:order-none animate-[float_6s_ease-in-out_infinite]"
      >
        <Bee class="w-full h-auto drop-shadow-[0_8px_18px_rgba(74,63,85,0.15)]" />
      </div>
    </section>

    {/* ---------- Gallery ---------- */}
    <section
      id="gallery"
      class="max-w-[1100px] mx-auto px-5 sm:px-8 lg:px-16 py-8 lg:py-14"
    >
      <SectionHead
        eyebrow="La collection"
        title="Rencontre les peluches."
        sub="Chacune est unique. Quand elle est partie, elle est partie — mais on peut t'en crocheter une nouvelle sur commande."
      />
      <div
        class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-4"
      >
        {plushies.map((p) => <PlushCard {...p} />)}
      </div>
    </section>

    {/* ---------- Order ---------- */}
    <section
      id="order"
      class="bg-peach-warm px-5 sm:px-8 lg:px-16 py-8 lg:py-14 mt-6 lg:mt-10"
    >
      <div class="max-w-[680px] mx-auto text-center">
        <Eyebrow>Comment ça marche ?</Eyebrow>
        <h2
          class="text-[clamp(1.6rem,3.5vw,2.4rem)] font-display font-bold mb-6"
        >
          Retrouve-nous à l'école.
        </h2>
        <ol class="list-none grid gap-3 text-left mb-6">
          {
            orderSteps.map((s, i) => (
              <Step num={i + 1} title={s.title}>
                {s.body}
              </Step>
            ))
          }
        </ol>
        <p class="text-plum-soft italic text-[0.9rem]">
          ✿ Tu veux une peluche sur mesure ? Demande à n'importe laquelle
          d'entre nous — on adore les défis.
        </p>
      </div>
    </section>

    {/* ---------- About / Manifesto ---------- */}
    <section
      id="about"
      class="relative overflow-hidden px-5 sm:px-8 lg:px-16 py-10 lg:py-16"
    >
      <div
        class="absolute inset-0 bg-gradient-to-b from-peach via-pink/20 to-peach pointer-events-none"
      >
      </div>

      <div
        class="relative z-10 flex justify-center gap-1.5 sm:gap-3 mb-5 sm:mb-6 opacity-70"
      >
        <div class="w-9 sm:w-12 -rotate-12">
          <Plush variant="bunny" color="#FFD6E0" accent="#FFB3C7" />
        </div>
        <div class="w-10 sm:w-13 -translate-y-2 rotate-3">
          <Plush variant="cat" color="#C8E6E0" accent="#A8D4CB" />
        </div>
        <div class="w-10 sm:w-13 -translate-y-2 -rotate-2">
          <Plush variant="unicorn" color="#D4C5F9" accent="#FFD6E0" />
        </div>
        <div class="w-9 sm:w-12 rotate-12">
          <Plush variant="fox" color="#FFC9A3" accent="#FFA77A" />
        </div>
      </div>

      <div class="relative z-10 max-w-[640px] mx-auto text-center">
        <Eyebrow>Notre atelier</Eyebrow>
        <h2
          class="text-[clamp(1.6rem,3.5vw,2.4rem)] font-display font-bold mb-4"
        >
          Quatre filles, un crochet, <em class="text-pink-deep font-bold"
            >mille idées.</em
          >
        </h2>
        <p class="text-plum-soft text-[0.98rem] mb-3">
          Chaque peluche est crochetée à la main à la maison, après les cours.
          On choisit la laine ensemble, on suit le patron (ou pas), on se
          chamaille pour les yeux, et on crochète jusqu'à ce que ce soit
          parfait.
        </p>
        <p class="text-plum-soft text-[0.98rem]">
          Pas d'usine, pas de machines, jamais deux pareilles. Chaque maille est
          faite à la main, et chaque peluche a un nom, un caractère, et une
          créatrice qui y a passé des heures.
        </p>

        <ul
          class="list-none mt-8 flex flex-col sm:flex-row sm:items-stretch sm:justify-center divide-y sm:divide-y-0 sm:divide-x divide-dashed divide-plum/25 max-w-md sm:max-w-none mx-auto"
        >
          {
            stats.map((s) => (
              <li class="flex flex-col items-center py-4 sm:py-0 sm:px-5 lg:px-8">
                <strong class="font-display font-black text-[1.9rem] sm:text-[2.2rem] text-plum leading-none">
                  {s.value}
                </strong>
                <span class="text-[0.7rem] sm:text-[0.75rem] text-plum-soft uppercase tracking-[0.12em] mt-1.5 text-center">
                  {s.label}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </main>
</Layout>

<style>
  @keyframes float {
    0%,
    100% {
      transform: translateY(0) rotate(-2deg);
    }
    50% {
      transform: translateY(-14px) rotate(2deg);
    }
  }
</style>
