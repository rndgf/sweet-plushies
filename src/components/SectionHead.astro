---
import Eyebrow from './Eyebrow.astro';

interface Props {
  eyebrow: string;
  title: string;
  sub?: string;
}
const { eyebrow, title, sub } = Astro.props;
---

<header class="text-center max-w-[520px] mx-auto mb-8">
  <Eyebrow class="block">{eyebrow}</Eyebrow>
  <h2 class="text-[clamp(1.6rem,3.5vw,2.4rem)] font-display font-bold mb-3">{title}</h2>
  {sub && <p class="text-plum-soft text-[0.95rem]">{sub}</p>}
</header>
